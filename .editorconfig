# ===================================================================
# EditorConfig - 统一代码风格配置
# ===================================================================
# https://editorconfig.org
# ===================================================================

# 根目录配置
root = true

# ===================================================================
# 通配符规则
# ===================================================================

[*]
# 字符集
charset = utf-8
# 结尾换行符
end_of_line = lf
# 插入最终换行符
insert_final_newline = true
# 删除行尾空白字符
trim_trailing_whitespace = true

# ===================================================================
# Java 文件
# ===================================================================

[*.java]
# 缩进样式：空格
indent_style = space
# 缩进大小：4
indent_size = 4
# 最大行长
max_line_length = 120

# ===================================================================
# YAML 文件
# ===================================================================

[*.{yml,yaml}]
indent_style = space
indent_size = 2

# ===================================================================
# JSON 文件
# ===================================================================

[*.json]
indent_style = space
indent_size = 2

# ===================================================================
# XML 文件
# ===================================================================

[*.{xml,xsd,xsl}]
indent_style = space
indent_size = 4

# ===================================================================
# Markdown 文件
# ===================================================================

[*.md]
trim_trailing_whitespace = false
max_line_length = off

# ===================================================================
# Shell 脚本
# ===================================================================

[*.sh]
indent_style = space
indent_size = 2
end_of_line = lf

# ===================================================================
# Properties 文件
# ===================================================================

[*.properties]
indent_style = space
indent_size = 2

# ===================================================================
# SQL 文件
# ===================================================================

[*.sql]
indent_style = space
indent_size = 2

# ===================================================================
# Maven POM 文件
# ===================================================================

[pom.xml]
indent_style = space
indent_size = 2
