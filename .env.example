# =============================================================================
# Claude-Mem Environment Configuration
# =============================================================================
# Copy this file to .env and configure for your environment:
#   cp .env.example .env
# =============================================================================

# =============================================================================
# Docker Image (optional)
# =============================================================================
# Override the default image if needed
IMAGE_NAME=ghcr.io/wubuku/claude-mem-java:latest
# Or use a specific version:
# IMAGE_NAME=ghcr.io/wubuku/claude-mem-java:sha-abc123

# =============================================================================
# Database Configuration
# =============================================================================
DB_NAME=claude_mem
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password_here

# =============================================================================
# Server Configuration
# =============================================================================
SERVER_PORT=37777

# =============================================================================
# Chat Model (OpenAI Compatible)
# =============================================================================
SPRING_PROFILES_ACTIVE=prd
SPRING_AI_OPENAI_API_KEY=your_openai_api_key_here
SPRING_AI_OPENAI_BASE_URL=https://api.openai.com
SPRING_AI_OPENAI_CHAT_MODEL=gpt-4o

# =============================================================================
# Embedding Model (for vector search)
# =============================================================================
SPRING_AI_OPENAI_EMBEDDING_API_KEY=your_embedding_api_key_here
SPRING_AI_OPENAI_EMBEDDING_BASE_URL=https://api.openai.com
SPRING_AI_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
SPRING_AI_OPENAI_EMBEDDING_DIMENSIONS=1536

# =============================================================================
# Observation Mode (code|chat)
# =============================================================================
CLAUDE_MEM_MODE=code

# =============================================================================
# Evo-Memory: Memory Refinement (Self-Evolution)
# =============================================================================
# Set to 'false' to disable automatic memory refinement/merging.
# This saves LLM token consumption.
# MEMORY_REFINE_ENABLED=false

# =============================================================================
# Advanced: Custom Java Options
# =============================================================================
# JAVA_OPTS=-XX:+UseZGC -XX:MaxRAMPercentage=75.0

# =============================================================================
# Advanced: Data Persistence Paths
# =============================================================================
# POSTGRES_DATA_PATH=./postgres_data
# LOGS_PATH=./logs
