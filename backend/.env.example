# OpenAI API 兼容模型配置
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat
# 使用 `OPENAI_` 前缀表示我们采用的是 OpenAI API 兼容的服务

# Anthropic API 兼容模型配置
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
ANTHROPIC_MODEL=GLM-5

# LLM 提供商选择: openai 或 anthropic
# - openai: 使用 OpenAI 兼容 API (DeepSeek 等)
# - anthropic: 使用 Anthropic 兼容 API (Claude, GLM 等)
CLAUDEMEM_LLM_PROVIDER=openai


# 嵌入模型配置（使用硅基流动提供的服务）
# SILICONFLOW_API_KEY=your-siliconflow-api-key-here
# SILICONFLOW_MODEL=BAAI/bge-m3
# SILICONFLOW_DIMENSIONS=1024
# SILICONFLOW_URL=https://api.siliconflow.cn

SPRING_AI_OPENAI_EMBEDDING_API_KEY=your-embedding-api-key-here
SPRING_AI_OPENAI_EMBEDDING_BASE_URL=https://api.siliconflow.cn
SPRING_AI_OPENAI_EMBEDDING_MODEL=BAAI/bge-m3
SPRING_AI_OPENAI_EMBEDDING_DIMENSIONS=1024


# ---------------------------------------------------------------------------
# **常用 shell 命令提示**

# 从 .env 文件中读取所有非注释行，将其解析为 KEY=VALUE 格式，
# 并一次性通过 export 将它们加载到当前 shell 的环境变量中：
# export $(cat .env | grep -v '^#' | xargs)

# 重启服务前，先精准kill占用特定端口的进程（不要滥杀无辜！）
# 方案1（推荐）：只杀 LISTEN 状态的进程，不会误杀客户端
# lsof -ti:37777 -sTCP:LISTEN | xargs -r kill -9 2>/dev/null; echo "Killed server on port 37777"; sleep 1; lsof -ti:37777 || echo "Port 37777 is free"
#
# 方案2：使用进程名精确匹配（更安全，不会误杀任何其他进程）
# pkill -f "java.*claude-mem-java" && echo "Killed java service"

# 执行 Maven 打包命令，跳过测试：
# ./mvnw package -DskipTests

# 将 .env 文件中的环境变量加载到当前 shell 中，并启动 Spring Boot 应用程序
# （假设使用 dev 配置文件，JAR 文件名为 claudemem-java-0.1.0-SNAPSHOT.jar）：
# export $(cat .env | grep -v '^#' | grep -v '^$' | xargs) 2>/dev/null; java -jar target/claude-mem-java-0.1.0-SNAPSHOT.jar --spring.profiles.active=dev
# ---------------------------------------------------------------------------
