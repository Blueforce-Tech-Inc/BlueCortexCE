# Conan Profile - Linux x86_64 GCC 12
# Usage: conan install . --profile=gcc12

[settings]
os=Linux
arch=x86_64
compiler=gcc
compiler.version=12
compiler.libcxx=libstdc++11
build_type=Release

[conf]
tools.build:compiler_executables={"c": "gcc-12", "cpp": "g++-12"}
tools.cmake.cmaketoolchain:generator=Ninja

[buildenv]
CC=gcc-12
CXX=g++-12

[options]
/* shared libs for faster builds, static for deployment */
