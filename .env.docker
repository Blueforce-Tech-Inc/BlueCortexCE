# =============================================================================
# Claude-Mem Docker Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.docker .env
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DB_NAME=claude_mem
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password_here

# -----------------------------------------------------------------------------
# OpenAI API Configuration (DeepSeek or compatible)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat

# -----------------------------------------------------------------------------
# SiliconFlow Embedding Configuration
# -----------------------------------------------------------------------------
SILICONFLOW_API_KEY=sk-your-siliconflow-key-here
SILICONFLOW_URL=https://api.siliconflow.cn
SILICONFLOW_MODEL=BAAI/bge-m3
SILICONFLOW_DIMENSIONS=1024

# -----------------------------------------------------------------------------
# Claude-Mem Configuration
# -----------------------------------------------------------------------------
CLAUDE_MEM_MODE=code
